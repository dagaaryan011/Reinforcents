import numpy as np
import pandas as pd
from datetime import date, timedelta
# from noise import generate_daily_price_path
import matplotlib.pyplot as plt

class Indicators:
    def __init__(self,trend):
        self.trend = trend
    def SMA_n(self, n:int):
        if len(self.trend) < n:
            return None, None
        prices_for_period = self.trend[-n:]
        price_array = np.array(prices_for_period)
        sma = np.mean(price_array)
        sd = np.std(price_array, ddof=1)
        return sma, sd

    def EMA_n(self, n:int):
        if len(self.trend) < n:
            return None
        price_series = pd.Series(self.trend)
        ema_series = price_series.ewm(span=n, adjust=False).mean()
        return ema_series.iloc[-1]

    def MACD(self):
        EMA_26 = self.EMA_n(self.trend,26)
        EMA_12 = self.EMA_n(self.trend,12)

        if EMA_12 is not None and EMA_26 is not None:
            macd_val = EMA_12 - EMA_26
            return macd_val
        else:
            return None
    def RSI(self):#14 is std RSI period , change in price of stock pe RSI banate hai
        if len(self.trend) < 14 + 1:
            return None
        window = self.trend[-(14 + 1):]
        positive_changes = []
        negative_changes = []
        for i in range(14):
            rate = window[i+1] - window[i]
            if rate > 0:
                positive_changes.append(rate)
            else:
                negative_changes.append(abs(rate))
        gains = positive_changes if positive_changes else [0]
        losses = negative_changes if negative_changes else [0]
        avg_gain = np.sum(gains) / 14
        avg_loss = np.sum(losses) / 14
        if avg_loss == 0:
            return 100.0
        rs = avg_gain / avg_loss
        rsi = 100 - (100 / (1 + rs))
        return rsi

    def Smooth_RSI(self):#14 is std value for RSI
        if len(self.trend) < 14 + 1:
            return None
        price_series = pd.Series(self.trend)
        delta = price_series.diff()
        gain = delta.where(delta > 0, 0)
        loss = -delta.where(delta < 0, 0)
        avg_gain = gain.ewm(com=14 - 1, adjust=False).mean()
        avg_loss = loss.ewm(com=14 - 1, adjust=False).mean()
        last_avg_loss = avg_loss.iloc[-1]
        if last_avg_loss == 0:
            return 100.0
        rs = avg_gain.iloc[-1] / last_avg_loss
        rsi = 100 - (100 / (1 + rs))
        return rsi


    def Stoch_Oscilator(self):
        if len(self.trend)<14:
            return None
        
        window = np.array(self.trend[-14:])
        low = np.min(window)
        high = np.max(window)
        if high == low :
            return 50

        else:
            closing_price = self.trend[-1]
            per_k = 100*(closing_price-low)/(high-low)
        return per_k
