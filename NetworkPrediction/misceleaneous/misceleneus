        print(prediction-1)
        
        
        return output - 1


    def macd_signal(self,n ):
        window_size: int = n
        if len(self.macd_history) < (2 * window_size) + 9:
            return 0

        end_window = self.macd_history[-window_size:]
        start_window = self.macd_history[-(2 * window_size):-window_size]

        macd_end = end_window[-1]
        macd_start = start_window[-1]

        signal_end = self.all_indicators.EMA_n(end_window, n=9)
        signal_start = self.all_indicators.EMA_n(start_window, n=9)

        if signal_end is None or signal_start is None:
            return 0

        if (macd_start - signal_start) <= 0 and (macd_end - signal_end) > 0:
            return 1

        elif (macd_start - signal_start) >= 0 and (macd_end - signal_end) < 0:
            return -1

        else:
            return 0
    def RSI_conviction(self):
        pass
    def get_rsi_signal(self,n):
        
        window_size: int = n
        rsi_period: int = 14
        if len(self.trend) < window_size + rsi_period + 1:
            return 0

        overbought_count = 0
        oversold_count = 0

        for i in range(window_size):
            current_trend_slice = self.trend[:-(window_size - i - 1)]

            rsi_value = self.all_indicators.Smooth_RSI(current_trend_slice, n=rsi_period)

            if rsi_value is not None:
                if rsi_value > 70:
                    overbought_count += 1
                elif rsi_value < 30:
                    oversold_count += 1

        if overbought_count > oversold_count:
            return 1
        elif oversold_count > overbought_count:
            return -1
        else:
            return 0    
    def get_stochastic_signal(self ):
        # Args:
        #     trend (list): The full history of price data.
        #     window_size (int): The number of time steps to check for signals.
        #     k_period (int): The lookback period for the %K calculation.


        # Returns:
        #     int: 1 if overbought signals were dominant, -1 if oversold signals
        #          were dominant, and 0 otherwise.

        window_size: int = 30
        k_period: int = 14
        if len(self.trend) < window_size + k_period:
            return 0

        overbought_count = 0
        oversold_count = 0

        for i in range(window_size):
            current_trend_slice = self.trend[:-(window_size - i - 1)]

            k_value = self.Stoch_Oscilator(current_trend_slice, n=k_period)

            if k_value is not None:
                if k_value > 80:
                    overbought_count += 1
                elif k_value < 20:
                    oversold_count += 1

        if overbought_count > oversold_count:
            return 1
        elif oversold_count > overbought_count:
            return -1
        else:
            return 0
    def get_current_status(trend: list[float]):
        
        total_steps = len(trend)
        steps_in_day = 375

        
        num_full_days = total_steps // steps_in_day

        
        start_of_current_day = num_full_days * steps_in_day

        
        current_day_trend = trend[start_of_current_day:]

        
        if not current_day_trend:
            return None

        highest_price = np.max(current_day_trend)
        lowest_price = np.min(current_day_trend)

        
        midpoint = (highest_price + lowest_price) / 2

        ratio = (current_day_trend[-1] - midpoint)/abs(highest_price-midpoint)
        return ratio

